{
  "name": "hieronymus-opentui",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "bun build src/main.tsx --outfile=dist/main.js --target=bun --external @opentui/core",
    "dev": "bun --watch src/main.tsx",
    "test": "bun test",
    "format": "prettier --check src",
    "format:write": "prettier --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.4.0",
    "@opentui/react": "0.4.0",
    "react": "^19",
    "unicode-animations": "^1.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
